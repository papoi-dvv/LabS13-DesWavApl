datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?   
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}